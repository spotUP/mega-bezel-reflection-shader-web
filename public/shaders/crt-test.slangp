# Minimal CRT Test - Just 2 passes
# Pass 0: Simple passthrough
# Pass 1: Bezel composite

shaders = 2

# Pass 0: Simple passthrough (no processing)
shader0 = passthrough.slang
filter_linear0 = true
scale_type0 = source
scale0 = 1.0
alias0 = "GamePass"

# Pass 1: Bezel/reflection composite
shader1 = simple-reflection.slang
filter_linear1 = true
scale_type1 = viewport
scale1 = 1.0
